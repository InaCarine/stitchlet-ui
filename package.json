{
  "name": "starter-project-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "storybook": "turbo run storybook",
    "lint": "turbo run lint --continue",
    "lint:css": "turbo run lint:css --continue",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:update": "turbo run test:update",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,css,scss,json,yml,yaml,html}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,md,css,scss,json,yml,yaml,html}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "clean": "turbo run clean && rm -rf node_modules && rm -rf pnpm-lock.yaml"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/config-pnpm-scopes": "^21.0.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "glob": "^10.5.0"
  }
}
